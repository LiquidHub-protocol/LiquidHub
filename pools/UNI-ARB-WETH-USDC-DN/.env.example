# =============================================================================
# Liquid Hub — Delta Neutral Pool Keeper (UNI-ARB-WETH-USDC-DN)
# =============================================================================
# Copy this file to .env and fill in your values.
# This is a community keeper configuration — you only need the variables
# required to run a keeper bot that calls public rebalance() and monitors
# the AAVE V3 hedge on the protocol.

# --- RPC Endpoints (Arbitrum) ---
# Primary RPC (required). Backups are optional but recommended for resilience.
RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BACKUP_1=
RPC_BACKUP_2=

# --- Contract Addresses ---
# Find the official deployed addresses on the protocol's Contracts page:
#   http://liquidhub.app/docs#contracts-addresses
# (Do not guess or hardcode addresses — always copy them from that page.)
RANGEMANAGER_ADDRESS=
VAULT_ADDRESS=
AAVE_HEDGE_MANAGER_ADDRESS=
# Optional but recommended: lets the keeper skip deposit processing/rebalance
# locally when the Safe circuit breaker has paused inflows. The contracts remain
# the final authority and will revert paused actions even if this is left blank.
# recordPriceSnapshot() and adjustHedge() stay available when inflows are paused.
PAUSE_CONTROLLER_ADDRESS=
# Treasury address (find it on the protocol's Contracts page). Optional but recommended:
# lets the keeper read the Treasury USDC balance and warn you when a bounty would be skipped
# because the Treasury is underfunded. If left blank, it is discovered via vault.treasuryAddress().
TREASURY_ADDRESS=

# --- Token Addresses (Arbitrum, already filled for WETH/USDC) ---
TOKEN0_ADDRESS=0x82af49447d8a07e3bd95bd0d56f35241523fbab1
TOKEN1_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
TOKEN0_DECIMALS=18
TOKEN1_DECIMALS=6

# --- Keeper Wallet ---
# Private key of the keeper wallet (funded with ETH for gas).
# Keepers earn USDC bounties from the Treasury (paid to whoever sends the tx):
#   - rebalance()           -> keeper bounty
#   - recordPriceSnapshot() -> metrics bounty (when a snapshot is due)
#   - adjustHedge()         -> hedge bounty (over-hedge only; under-hedge uses rebalance())
# Bounties are only paid when enabled AND the Treasury holds enough USDC; otherwise the action
# still succeeds but no bounty is paid. Verify the Treasury balance on-chain before relying on it.
KEEPER_PRIVATE_KEY=

# --- Keeper Timing ---
# How often the keeper polls getBotInstructions() (in minutes).
# Lower = more responsive but uses more RPC calls. 10 is a good default.
CHECK_INTERVAL_MIN=10

# --- AAVE V3 Health Factor Thresholds (Delta Neutral hedge) ---
# WARN: hedge is still safe but monitored
# DELEVERAGE: hedge is repaid partially to restore safety
# EMERGENCY: full close of the hedge to avoid liquidation
AAVE_HEALTH_WARN=1.40
AAVE_HEALTH_DELEVERAGE=1.25
AAVE_HEALTH_EMERGENCY=1.15
